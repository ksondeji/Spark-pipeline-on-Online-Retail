# Copier vers .env — utilisé en local uniquement (ignoré sur Databricks)

ENV=dev

# Surcharge des chemins (sinon config/{ENV}.yaml)
# RAW_PATH=data/raw/Online_Retail.csv
# BRONZE_PATH=data/bronze
# SILVER_PATH=data/silver
# GOLD_PATH=data/gold

# --- Databricks : ne pas utiliser .env ---
# Définir les chemins dans config/databricks.yaml (Unity Catalog / Volumes)
# ou en paramètres de job :
#   ENV=databricks
#   RAW_PATH=/Volumes/catalog/schema/raw/Online_Retail.csv
#   BRONZE_PATH=/Volumes/catalog/schema/bronze
#   ...
