# Copier ce fichier vers .env et adapter les valeurs (le fichier .env n’est pas versionné).

ENV=dev

# Source brute : fichier local ou objet cloud (utiliser le schéma attendu par Spark : file://..., s3a://..., abfs://...)
# Exemple local Windows :
# RAW_PATH=file:///C:/chemin/vers/Data_OR/Online_Retail.csv
# Exemple S3 (nécessite les jars Hadoop AWS + identifiants IAM ou variables AWS_) :
# RAW_PATH=s3a://mon-bucket/raw/online_retail/Online_Retail.csv

RAW_PATH=

# Répertoire warehouse Spark / tables Delta curated (tables créées avec saveAsTable iront sous ce préfixe)
# Laisser vide pour utiliser le warehouse par défaut (ex. ./spark-warehouse en local)
# CURATED_PATH=s3a://mon-bucket/curated/warehouse

CURATED_PATH=
